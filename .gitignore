# =============================================================
#  NLPCortexSQL — .gitignore
# =============================================================

# -------------------------------------------------------------
# CREDENTIALS & SECRETS  (never push these)
# -------------------------------------------------------------
.env
.env.*
.env.local
.env.development
.env.staging
.env.production
*.pem
*.key
*.p12
*.pfx
*.jks
*_rsa
*_dsa
*_ecdsa
*_ed25519
secrets/
credentials/
.aws/
service-account*.json
google-credentials*.json
firebase*.json

# -------------------------------------------------------------
# ML MODEL — fine-tuned folder (exceeds GitHub 25 MB limit)
# -------------------------------------------------------------
fine_tuned_sql_model/
**/fine_tuned_sql_model/
*.bin
*.pt
*.pth
*.safetensors
*.onnx
*.gguf
*.pkl
*.pickle

# -------------------------------------------------------------
# PYTHON
# -------------------------------------------------------------
__pycache__/
*/__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so
*.dll
*.dylib
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
.venv312/
*venv/
env/
ENV/

# Python version file (optional — remove if you want to commit it)
# .python-version

# -------------------------------------------------------------
# RUNTIME / GENERATED FILES
# -------------------------------------------------------------
agent_memory.json
*.log
*.sqlite
*.sqlite3
*.db

# Alembic (keep alembic.ini but ignore auto-generated versions if needed)
# alembic/versions/

# -------------------------------------------------------------
# NODE / FRONTEND
# -------------------------------------------------------------
node_modules/
dist/
.next/
.nuxt/
.output/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -------------------------------------------------------------
# OS & EDITOR ARTIFACTS
# -------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# -------------------------------------------------------------
# MISC
# -------------------------------------------------------------
*.zip
*.tar.gz
*.rar
coverage/
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/